generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  FAN
  BAND
  ADMIN
}

enum BandStatus {
  PENDING
  VERIFIED
  SUSPENDED
}

enum ContentType {
  SHOW
  DOCUMENTARY
  EXCLUSIVE
  LIVE_RECORDING
}

enum AccessLevel {
  FREE
  SUBSCRIPTION
  PURCHASE
}

enum LiveShowStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

enum ProductType {
  TSHIRT
  VINYL
  CD
  POSTER
  OTHER
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum TransactionType {
  SUBSCRIPTION
  PPV
  MARKETPLACE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(FAN)
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  band            Band?
  subscriptions   UserSubscription[]
  ppvTickets      PpvTicket[]
  orders          Order[]
  payments        Payment[]
  bandFollows     BandFollow[]
  contentAccesses ContentAccess[]

  @@map("users")
}

model Band {
  id          String     @id @default(cuid())
  userId      String     @unique
  name        String
  slug        String     @unique
  bio         String?
  imageUrl    String?
  status      BandStatus @default(PENDING)
  verifiedAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  contents   Content[]
  liveShows  LiveShow[]
  products   Product[]
  earnings   BandEarning[]
  followers  BandFollow[]

  @@map("bands")
}

model BandFollow {
  id        String   @id @default(cuid())
  userId    String
  bandId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  band Band @relation(fields: [bandId], references: [id], onDelete: Cascade)

  @@unique([userId, bandId])
  @@map("band_follows")
}

model SubscriptionPlan {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?
  priceCents   Int
  currency     String   @default("BRL")
  intervalDays Int      @default(30)
  features     String[]
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscriptions UserSubscription[]

  @@map("subscription_plans")
}

model UserSubscription {
  id        String             @id @default(cuid())
  userId    String
  planId    String
  status    SubscriptionStatus @default(ACTIVE)
  startsAt  DateTime           @default(now())
  expiresAt DateTime
  cancelledAt DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([userId, status])
  @@map("user_subscriptions")
}

model Content {
  id          String      @id @default(cuid())
  bandId      String
  title       String
  description String?
  type        ContentType
  accessLevel AccessLevel @default(SUBSCRIPTION)
  durationMin Int?
  thumbnailUrl String?
  streamUrl   String?
  priceCents  Int?
  isPublished Boolean     @default(false)
  publishedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  band     Band            @relation(fields: [bandId], references: [id], onDelete: Cascade)
  accesses ContentAccess[]

  @@index([bandId, isPublished])
  @@map("contents")
}

model ContentAccess {
  id         String   @id @default(cuid())
  userId     String
  contentId  String
  grantedAt  DateTime @default(now())
  expiresAt  DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@map("content_accesses")
}

model LiveShow {
  id          String         @id @default(cuid())
  bandId      String
  title       String
  description String?
  scheduledAt DateTime
  endsAt      DateTime?
  priceCents  Int
  status      LiveShowStatus @default(SCHEDULED)
  streamUrl   String?
  thumbnailUrl String?
  maxViewers  Int?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  band    Band        @relation(fields: [bandId], references: [id], onDelete: Cascade)
  tickets PpvTicket[]

  @@index([bandId, scheduledAt])
  @@index([status, scheduledAt])
  @@map("live_shows")
}

model PpvTicket {
  id         String   @id @default(cuid())
  userId     String
  liveShowId String
  paymentId  String   @unique
  purchasedAt DateTime @default(now())
  accessFrom DateTime
  accessUntil DateTime

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  liveShow LiveShow @relation(fields: [liveShowId], references: [id], onDelete: Cascade)
  payment  Payment  @relation(fields: [paymentId], references: [id])

  @@unique([userId, liveShowId])
  @@map("ppv_tickets")
}

model Product {
  id          String      @id @default(cuid())
  bandId      String
  name        String
  description String?
  type        ProductType
  priceCents  Int
  stock       Int         @default(0)
  imageUrl    String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  band       Band        @relation(fields: [bandId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([bandId, isActive])
  @@map("products")
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  status      OrderStatus @default(PENDING)
  totalCents  Int
  currency    String      @default("BRL")
  shippingAddress Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items OrderItem[]
  payments Payment[]

  @@index([userId, status])
  @@map("orders")
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  productId  String
  quantity   Int
  unitPriceCents Int
  bandId     String

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Payment {
  id              String          @id @default(cuid())
  userId          String
  orderId         String?
  type            TransactionType
  status          PaymentStatus   @default(PENDING)
  grossAmountCents Int
  platformFeeCents Int
  bandAmountCents  Int
  currency        String          @default("BRL")
  bandId          String?
  metadata        Json?
  externalId      String?
  paidAt          DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  order     Order?     @relation(fields: [orderId], references: [id])
  ppvTicket PpvTicket?
  earning   BandEarning?

  @@index([userId, type, status])
  @@index([bandId])
  @@map("payments")
}

model BandEarning {
  id         String       @id @default(cuid())
  bandId     String
  paymentId  String       @unique
  amountCents Int
  status     PayoutStatus @default(PENDING)
  paidAt     DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  band    Band    @relation(fields: [bandId], references: [id], onDelete: Cascade)
  payment Payment @relation(fields: [paymentId], references: [id])

  @@index([bandId, status])
  @@map("band_earnings")
}
